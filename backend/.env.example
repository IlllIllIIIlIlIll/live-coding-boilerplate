# Server
PORT=5000
# Boleh berisi beberapa origin dipisah koma (untuk CORS), mis. saat akses dari HP via LAN IP
FRONTEND_URL=http://localhost:5173

# Database (MySQL)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=tes_live_coding
DB_USER=root
DB_PASSWORD=
# Set ke "false" kalau DB_HOST mengarah ke database production, supaya sync() tidak
# menjalankan ALTER TABLE terhadap schema live setiap kali dev server start.
DB_SYNC_ALTER=true

# JWT
JWT_SECRET=ganti_dengan_secret_yang_kuat
JWT_EXPIRES_IN=1d

# OTP
OTP_EXPIRES_MINUTES=5

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback

# Web Push (VAPID) — generate dengan: node -e "console.log(require('web-push').generateVAPIDKeys())"
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com
PUSH_POLL_INTERVAL_MS=60000

# Firebase Admin (FCM push ke aplikasi Android native) — opsional, isi seluruh
# isi file service-account JSON dari Firebase Console sebagai satu baris JSON.
# Kalau kosong, FCM dilewati otomatis dan Web Push tetap berjalan normal.
FIREBASE_SERVICE_ACCOUNT_JSON=
